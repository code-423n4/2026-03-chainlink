  },
  "devDependencies": {
    "@uniswap/swap-router-contracts": "1.3.1",
    "@uniswap/v3-core": "1.0.1",
    "forge-std": "github:foundry-rs/forge-std#1801b0541f4fda118a10798fd3486bb7051c5dd6",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
